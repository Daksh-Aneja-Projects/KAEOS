# =============================================================================
# KAEOS — Environment Variables Reference
# Enterprise Workforce Operating System (EWOS)
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=KAEOS

# ─── Core Security ────────────────────────────────────────────────────────────
# DEV_MODE bypasses authentication and uses a dev tenant. It is OFF by default.
# Set to true ONLY for local development. The app refuses to start with DEV_MODE
# off unless SECRET_KEY and ADMIN_SECRET are set to real values.
DEV_MODE=false

# REQUIRED when DEV_MODE=false. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# REQUIRED when DEV_MODE=false. Guards the /admin/security/api-keys endpoints.
# Must be unique (not 'dev_secret' / 'dev_admin_2026').
ADMIN_SECRET=your-unique-admin-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development default — zero external services)
DATABASE_URL=sqlite+aiosqlite:///./kaeos.db
DATABASE_URL_SYNC=sqlite:///./kaeos.db

# PostgreSQL (production — required for Alembic migrations + pgvector polystore)
# DATABASE_URL=postgresql+asyncpg://kaeos:password@localhost:5432/kaeos
# DATABASE_URL_SYNC=postgresql://kaeos:password@localhost:5432/kaeos

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required for: HITL persistence, EventBus pub/sub, APScheduler
REDIS_URL=redis://localhost:6379/0

# ─── LLM Providers ────────────────────────────────────────────────────────────
# At least one is required for agent execution
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: Google Gemini
GOOGLE_API_KEY=AIza...

# Optional: BYOK (bring your own key) via LiteLLM proxy
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_PROXY_API_KEY=

# ─── Graph Database (Optional) ────────────────────────────────────────────────
# Enterprise Graph / Digital Twin. Falls back to in-memory if not set.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ─── Vector Store (Optional) ──────────────────────────────────────────────────
# pgvector for semantic retrieval. Requires PostgreSQL with pgvector extension.
PGVECTOR_ENABLED=false

# ─── Observability ────────────────────────────────────────────────────────────
OPENTELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Sentry error tracking
SENTRY_DSN=

# ─── Auth & Multi-Tenancy ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins in production
# CORS_ORIGINS=https://app.yourcompany.com,https://admin.yourcompany.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── SAML / SSO (Enterprise) ─────────────────────────────────────────────────
# SAML_IDP_METADATA_URL=https://your-idp.com/metadata
# SAML_SP_ENTITY_ID=https://kaeos.yourcompany.com
# SAML_SP_ACS_URL=https://kaeos.yourcompany.com/api/auth/saml/callback

# ─── External Connectors ─────────────────────────────────────────────────────
# BambooHR
BAMBOOHR_API_KEY=
BAMBOOHR_SUBDOMAIN=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# JIRA / Atlassian
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=

# Workday
WORKDAY_TENANT_NAME=
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_PRECOG_ENGINE=true
ENABLE_PHYSICS_ENGINE=true
ENABLE_HITL=true
ENABLE_DEBATE_ENGINE=true
ENABLE_FEDERATED_LEARNING=false

# ─── Decay Scheduler ──────────────────────────────────────────────────────────
# How often the skill decay scheduler runs (minutes)
DECAY_INTERVAL_MINUTES=60
